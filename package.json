{
  "name": "airaie-studios",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:workflow": "turbo run dev --filter=workflow-studio",
    "dev:agent": "turbo run dev --filter=agent-studio",
