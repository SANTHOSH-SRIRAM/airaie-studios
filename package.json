    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.21",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.5.207",
    "react-pdf": "^10.4.1",
    "react-zoom-pan-pinch": "^3.7.0",
    "three": "^0.183.2"
  }
