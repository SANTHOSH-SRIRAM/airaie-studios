{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@airaie/ui": ["packages/ui/src"],
      "@airaie/shared": ["packages/shared/src"],
      "@airaie/shell": ["packages/shell/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
